---
import { withBase } from "../lib/base";
import { site } from "../data/site";
import { getContent, localizePath, type Lang } from "../i18n/content";

const { lang = "es" } = Astro.props as { lang?: Lang };
const t = getContent(lang);
const homeHref = withBase(localizePath("/", lang));
const nav = [
  { label: t.nav.quienes, href: `${homeHref}#quienes` },
  { label: t.nav.escuelas, href: `${homeHref}#escuelas` },
  { label: t.nav.mision, href: `${homeHref}#mision` },
  { label: t.nav.servir, href: withBase(localizePath("/servir", lang)) },
  { label: t.nav.contacto, href: `${homeHref}#contacto` },
];
const year = 2026;
---
<footer class="relative bg-[var(--color-secondary)] text-white pt-16 pb-8 overflow-hidden">
  <div class="absolute -top-24 right-0 w-[26rem] h-[26rem] rounded-full blur-3xl opacity-15" aria-hidden="true" style="background: radial-gradient(circle, #4ec3e0, transparent 60%);"></div>
  <div class="container-xl relative z-10">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <div class="lg:col-span-1">
        <img src={withBase("/logo-white.png")} alt={site.name} width="220" height="58" class="h-12 w-auto mb-4" />
        <p class="text-white/70 leading-relaxed max-w-xs">{t.hero.titlePre} {t.hero.titleEm}.</p>
      </div>
      <div>
        <p class="text-sm uppercase tracking-wider text-white/50 mb-4">{t.footer.navHeading}</p>
        <ul class="space-y-2">
          {nav.map((l) => (<li><a href={l.href} class="text-white/90 hover:text-[var(--color-accent)] transition">{l.label}</a></li>))}
        </ul>
      </div>
      <div>
        <p class="text-sm uppercase tracking-wider text-white/50 mb-4">{t.footer.contactHeading}</p>
        <ul class="space-y-2 text-white/90">
          <li><a href={`tel:${site.phoneRaw}`} class="hover:text-[var(--color-accent)] transition">{site.phoneDisplay}</a></li>
          <li><a href={`mailto:${site.email}`} class="hover:text-[var(--color-accent)] transition break-all">{site.email}</a></li>
          <li class="text-white/70">{site.address}</li>
        </ul>
      </div>
      <div>
        <p class="text-sm uppercase tracking-wider text-white/50 mb-4">{t.footer.followHeading}</p>
        <div class="flex gap-3">
          <a href={site.socials.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="w-10 h-10 flex items-center justify-center bg-white/10 rounded-full hover:bg-[var(--color-accent)] hover:text-[var(--color-secondary)] transition">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href={site.socials.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="w-10 h-10 flex items-center justify-center bg-white/10 rounded-full hover:bg-[var(--color-accent)] hover:text-[var(--color-secondary)] transition">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={site.socials.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="w-10 h-10 flex items-center justify-center bg-white/10 rounded-full hover:bg-[var(--color-accent)] hover:text-[var(--color-secondary)] transition">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
        <p class="mt-6 text-sm text-white/60">{t.footer.partOf}</p>
      </div>
    </div>
    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row gap-3 justify-between text-sm text-white/60">
      <p>© {year} {site.name}. {t.footer.rights}</p>
      <p>{t.footer.madeBy} <a href="https://pandorastudio.cl" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)] transition">Pandora Studio</a></p>
    </div>
  </div>
</footer>
