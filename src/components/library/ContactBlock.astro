---
/**
 * ContactBlock — Formulario de contacto + canales directos
 * (WhatsApp prominente, teléfono, email). Layout split:
 * datos a la izquierda, form a la derecha.
 *
 * WhatsApp PROMINENTE porque para pymes chilenas suele ser
 * el canal #1 de conversión.
 *
 * El form posta a Web3Forms o Formspree por default — pasá el
 * `formAction` con tu endpoint. Si lo dejás vacío, el form no
 * funciona (es a propósito, te obliga a configurar).
 */

interface Props {
  title?: string;
  /** Texto debajo del título, idealmente con la promesa de respuesta */
  intro?: string;
  /** Número de WhatsApp en formato internacional con +. Ej: "+56998931002" */
  whatsapp?: string;
  /** Mensaje pre-rellenado para WhatsApp (URL-encoded automáticamente) */
  whatsappMessage?: string;
  /** Teléfono visible en formato amigable (ej "+56 2 2407 6220") */
  phoneDisplay?: string;
  /** Teléfono en formato tel: (ej "+56224076220") */
  phoneRaw?: string;
  email?: string;
  /** Dirección física opcional */
  address?: string;
  /** Endpoint del form. Ej: https://api.web3forms.com/submit */
  formAction?: string;
  /** Access key de Web3Forms (si usás eso) */
  formAccessKey?: string;
  /** Si está activo el form (true por default si hay formAction) */
  showForm?: boolean;
  id?: string;
}

const {
  title = "Conversemos",
  intro,
  whatsapp,
  whatsappMessage = "Hola, me interesa cotizar",
  phoneDisplay,
  phoneRaw,
  email,
  address,
  formAction,
  formAccessKey,
  showForm = true,
  id,
} = Astro.props;

const whatsappHref = whatsapp
  ? `https://wa.me/${whatsapp.replace(/[^0-9]/g, "")}?text=${encodeURIComponent(whatsappMessage)}`
  : null;
---

<section
  id={id}
  class="py-[var(--space-section)] lg:py-[var(--space-section-lg)]"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">
      <div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl mb-4">{title}</h2>
        {intro && (
          <p class="text-lg text-[var(--color-muted)] leading-relaxed mb-8">
            {intro}
          </p>
        )}

        <div class="space-y-4">
          {whatsappHref && (
            <a
              href={whatsappHref}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 p-4 bg-[#25D366] text-white rounded-[var(--radius-card)] font-semibold transition hover:bg-[#1da851]"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413"/>
              </svg>
              <span>WhatsApp {whatsapp}</span>
            </a>
          )}

          {phoneRaw && (
            <a
              href={`tel:${phoneRaw}`}
              class="flex items-center gap-3 p-4 border border-[var(--color-muted)]/30 rounded-[var(--radius-card)] hover:border-[var(--color-primary)]"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <span class="font-semibold">{phoneDisplay ?? phoneRaw}</span>
            </a>
          )}

          {email && (
            <a
              href={`mailto:${email}`}
              class="flex items-center gap-3 p-4 border border-[var(--color-muted)]/30 rounded-[var(--radius-card)] hover:border-[var(--color-primary)] break-all"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <span>{email}</span>
            </a>
          )}

          {address && (
            <p class="flex items-start gap-3 p-4 text-[var(--color-muted)]">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span>{address}</span>
            </p>
          )}
        </div>
      </div>

      {showForm && (
        <form
          action={formAction}
          method="POST"
          class="bg-[var(--color-surface)] p-6 lg:p-8 rounded-[var(--radius-card)] space-y-4"
          id="contactForm"
        >
          {formAccessKey && (
            <input type="hidden" name="access_key" value={formAccessKey} />
          )}
          <input type="hidden" name="subject" value="Nueva cotización desde el sitio" />
          <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

          <div>
            <label for="name" class="block text-sm font-semibold mb-1.5">Nombre</label>
            <input
              type="text"
              name="name"
              id="name"
              required
              class="w-full px-4 py-3 border border-[var(--color-muted)]/30 rounded-[var(--radius-button)] focus:border-[var(--color-primary)] focus:outline-none"
            />
          </div>

          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="email" class="block text-sm font-semibold mb-1.5">Email</label>
              <input
                type="email"
                name="email"
                id="email"
                required
                class="w-full px-4 py-3 border border-[var(--color-muted)]/30 rounded-[var(--radius-button)] focus:border-[var(--color-primary)] focus:outline-none"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold mb-1.5">Teléfono</label>
              <input
                type="tel"
                name="phone"
                id="phone"
                class="w-full px-4 py-3 border border-[var(--color-muted)]/30 rounded-[var(--radius-button)] focus:border-[var(--color-primary)] focus:outline-none"
              />
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold mb-1.5">¿En qué te ayudamos?</label>
            <textarea
              name="message"
              id="message"
              rows="4"
              required
              class="w-full px-4 py-3 border border-[var(--color-muted)]/30 rounded-[var(--radius-button)] focus:border-[var(--color-primary)] focus:outline-none resize-y"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full py-3.5 bg-[var(--color-primary)] text-white font-semibold rounded-[var(--radius-button)] hover:bg-[var(--color-secondary)] transition"
          >
            Enviar cotización
          </button>
        </form>
      )}
    </div>
  </div>
</section>
