---
/**
 * FAQ — Lista de preguntas frecuentes. Usa <details>/<summary>
 * nativo (sin JS, accesible, expandible).
 *
 * Tip: SEO-wise, pasar el array también como FAQPage schema en
 * el BaseLayout schemaJsonLd para obtener rich results.
 */

interface QA {
  question: string;
  answer: string;
}

interface Props {
  title?: string;
  intro?: string;
  items: QA[];
  id?: string;
}

const { title = "Preguntas frecuentes", intro, items, id } = Astro.props;
---

<section
  id={id}
  class="py-[var(--space-section)] lg:py-[var(--space-section-lg)] bg-[var(--color-surface)]"
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl mb-6">{title}</h2>
    {intro && (
      <p class="text-lg text-[var(--color-muted)] leading-relaxed mb-10">
        {intro}
      </p>
    )}

    <div class="space-y-3">
      {items.map((qa) => (
        <details class="group bg-white rounded-[var(--radius-card)] overflow-hidden">
          <summary class="flex items-center justify-between gap-4 p-5 lg:p-6 cursor-pointer font-semibold text-[var(--color-ink)] list-none select-none">
            <span>{qa.question}</span>
            <span
              aria-hidden="true"
              class="shrink-0 text-2xl text-[var(--color-primary)] transition-transform group-open:rotate-45"
            >+</span>
          </summary>
          <div class="px-5 lg:px-6 pb-5 lg:pb-6 text-[var(--color-ink)]/80 leading-relaxed">
            {qa.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  details > summary::-webkit-details-marker {
    display: none;
  }
</style>
