---
import { getContent, type Lang } from "../../i18n/content";
const { lang = "es" } = Astro.props as { lang?: Lang };
const t = getContent(lang).testimonials;
---
<section class="py-[var(--space-section)] lg:py-[var(--space-section-lg)] bg-[var(--color-sky-soft)]">
  <div class="container-xl">
    <div class="text-center max-w-2xl mx-auto mb-12 reveal">
      <p class="eyebrow mb-4">{t.eyebrow}</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold">{t.heading}</h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {t.items.map((it) => (
        <figure class="card-lift bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-soft)] p-7 flex flex-col">
          <svg width="34" height="34" viewBox="0 0 24 24" fill="var(--color-sky)" class="mb-3"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
          <blockquote class="text-[var(--color-ink)] leading-relaxed flex-1">{it.quote}</blockquote>
          <figcaption class="mt-5 flex items-center gap-3">
            <span class="w-11 h-11 rounded-full bg-[var(--color-sky-soft)] border border-[color:color-mix(in_srgb,var(--color-primary)_18%,transparent)] flex items-center justify-center text-[var(--color-primary)]">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg>
            </span>
            <span>
              <span class="block font-display font-semibold text-[var(--color-ink)] leading-tight">{it.name}</span>
              <span class="block text-sm text-[var(--color-muted)]">{it.role}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
    <p class="mt-8 text-center text-sm text-[var(--color-muted)]">{t.note}</p>
  </div>
</section>
