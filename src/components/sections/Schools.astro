---
import { getCollection } from "astro:content";
import { withBase } from "../../lib/base";
import { getContent, localizePath, type Lang } from "../../i18n/content";
const { lang = "es" } = Astro.props as { lang?: Lang };
const t = getContent(lang).schools;
const homeHref = withBase(localizePath("/", lang));
const pool = ["biblia-manos", "estudio-mesa", "comunidad", "leyendo", "adoracion", "araucania"];
let gi = 0;

// Escuelas desde el CMS (colección), filtradas por idioma (carpeta) y agrupadas.
const all = (await getCollection("escuelas", ({ id, data }) => !data.draft && id.startsWith(lang + "/")))
  .sort((a, b) => a.data.order - b.data.order);
const GROUP_KEYS = ["internas", "verano", "extensivas"] as const;
const groups = GROUP_KEYS.map((key, i) => ({
  label: t.groups[i].label,
  note: t.groups[i].note,
  items: all.filter((e) => e.data.group === key).map((e) => e.data),
})).filter((g) => g.items.length > 0);
---
<section id="escuelas" class="py-[var(--space-section)] lg:py-[var(--space-section-lg)] bg-[var(--color-sky-soft)]">
  <div class="container-xl">
    <div class="text-center max-w-2xl mx-auto mb-14 reveal">
      <p class="eyebrow mb-4">{t.eyebrow}</p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold">{t.heading}</h2>
      <p class="mt-4 text-lg text-[var(--color-muted)] leading-relaxed">{t.sub}</p>
    </div>

    {groups.map((g) => (
      <div class="mb-14 last:mb-0">
        <div class="flex flex-wrap items-baseline justify-between gap-2 mb-6 reveal">
          <h3 class="font-display text-xl sm:text-2xl font-bold text-[var(--color-primary)]">{g.label}</h3>
          <span class="text-sm text-[var(--color-muted)]">{g.note}</span>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {g.items.map((s) => {
            const img = pool[gi++ % pool.length];
            return (
              <article class="card-lift bg-white rounded-[var(--radius-card)] shadow-[var(--shadow-soft)] overflow-hidden flex flex-col">
                <div class="relative aspect-[16/10] overflow-hidden">
                  <img src={withBase(`/fotos/${img}.jpg`)} alt={s.title} class="ph" loading="lazy" />
                  <span class="tag-badge">{s.tag}</span>
                </div>
                <div class="p-5 flex flex-col flex-1">
                  <h4 class="font-display font-bold text-[1.05rem] leading-snug">{s.title}</h4>
                  {s.full && <p class="text-sm text-[var(--color-muted)] mt-0.5">{s.full}</p>}
                  <p class="mt-3 text-[var(--color-muted)] leading-relaxed text-[0.92rem] flex-1">{s.desc}</p>
                  <hr class="rule my-4" />
                  <div class="course-meta">
                    <span class="inline-flex items-center gap-1.5">
                      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                      {s.tag}
                    </span>
                    {s.date && (
                      <span class="inline-flex items-center gap-1.5">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        {s.date}
                      </span>
                    )}
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    ))}

    <p class="mt-10 text-center text-sm text-[var(--color-muted)]">
      <span set:html={t.soon}></span>
      <a href={`${homeHref}#contacto`} class="text-[var(--color-primary)] font-semibold underline underline-offset-2">{t.soonLink}</a> {t.soonAfter}
    </p>
  </div>
</section>
