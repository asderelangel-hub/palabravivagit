---
import { site } from "../../data/site";
import { withBase } from "../../lib/base";
import { getContent, localizePath, type Lang } from "../../i18n/content";

const { lang = "es" } = Astro.props as { lang?: Lang };
const c = getContent(lang);
const t = c.contact;
const cta = c.ctaBanner;
const homeHref = withBase(localizePath("/", lang));
const whatsappHref = `https://wa.me/${site.whatsapp.replace(/[^0-9]/g, "")}?text=${encodeURIComponent(site.whatsappMessage)}`;
const mapQuery = encodeURIComponent(site.address);
---
<section id="contacto" class="py-[var(--space-section)] lg:py-[var(--space-section-lg)] bg-[var(--color-surface)]">
  <div class="container-xl">
    <!-- Banner CTA -->
    <div class="reveal rounded-[var(--radius-card)] overflow-hidden text-white text-center px-6 py-14 sm:py-20 mb-16 relative bg-[var(--color-secondary)]">
      <span class="rule-accent mx-auto mb-6 block"></span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white max-w-2xl mx-auto">{cta.heading}</h2>
      <p class="mt-4 text-white/80 text-lg max-w-xl mx-auto">{cta.sub}</p>
      <div class="mt-8 flex flex-wrap gap-3 justify-center">
        <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="btn btn-white">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
          {cta.whatsapp}
        </a>
        <a href={`${homeHref}#escuelas`} class="btn btn-outline-white">{cta.ver}</a>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16">
      <div class="reveal">
        <p class="eyebrow mb-4">{t.eyebrow}</p>
        <h3 class="text-2xl sm:text-3xl font-bold">{t.heading}</h3>
        <p class="mt-3 text-[var(--color-muted)] leading-relaxed">{t.sub}</p>

        <div class="mt-7 space-y-3">
          <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-4 bg-[#25D366] text-white rounded-[var(--radius-button)] font-semibold hover:brightness-95 transition">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
            <span>{site.phoneDisplay}</span>
          </a>
          <a href={`mailto:${site.email}`} class="flex items-center gap-3 p-4 border border-[var(--color-muted)]/25 rounded-[var(--radius-button)] hover:border-[var(--color-primary)] transition break-all">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span>{site.email}</span>
          </a>
          <p class="flex items-start gap-3 p-4 text-[var(--color-muted)]">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>{site.address}</span>
          </p>
        </div>

        <div class="mt-6 rounded-[var(--radius-card)] overflow-hidden border border-[var(--color-sky)]/40 shadow-[var(--shadow-soft)]">
          <iframe title="Mapa" src={`https://www.google.com/maps?q=${mapQuery}&output=embed`} width="100%" height="240" style="border:0;" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>

      <form
        action={withBase("/contact.php")} method="POST"
        class="reveal bg-white p-6 lg:p-8 rounded-[var(--radius-card)] shadow-[var(--shadow-soft)] border border-[var(--color-sky)]/30 space-y-4"
        data-contact-form
        data-ok={t.form.ok} data-err={t.form.err} data-sending={t.form.sending} data-sent={t.form.sent}
      >
        <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
        <div>
          <label for="name" class="block text-sm font-semibold mb-1.5">{t.form.name}</label>
          <input type="text" name="name" id="name" required class="w-full px-4 py-3 border border-[var(--color-muted)]/25 rounded-[var(--radius-button)] focus:border-[var(--color-primary)] focus:outline-none" />
        </div>
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="email" class="block text-sm font-semibold mb-1.5">{t.form.email}</label>
            <input type="email" name="email" id="email" required class="w-full px-4 py-3 border border-[var(--color-muted)]/25 rounded-[var(--radius-button)] focus:border-[var(--color-primary)] focus:outline-none" />
          </div>
          <div>
            <label for="phone" class="block text-sm font-semibold mb-1.5">{t.form.phone}</label>
            <input type="tel" name="phone" id="phone" class="w-full px-4 py-3 border border-[var(--color-muted)]/25 rounded-[var(--radius-button)] focus:border-[var(--color-primary)] focus:outline-none" />
          </div>
        </div>
        <div>
          <label for="interest" class="block text-sm font-semibold mb-1.5">{t.form.interest}</label>
          <select name="interest" id="interest" class="w-full px-4 py-3 border border-[var(--color-muted)]/25 rounded-[var(--radius-button)] focus:border-[var(--color-primary)] focus:outline-none bg-white">
            {t.form.interestOptions.map((o) => <option>{o}</option>)}
          </select>
        </div>
        <div>
          <label for="message" class="block text-sm font-semibold mb-1.5">{t.form.message}</label>
          <textarea name="message" id="message" rows="4" required class="w-full px-4 py-3 border border-[var(--color-muted)]/25 rounded-[var(--radius-button)] focus:border-[var(--color-primary)] focus:outline-none resize-y"></textarea>
        </div>
        <input type="hidden" name="elapsed" value="0" data-elapsed />
        <button type="submit" class="btn btn-primary w-full" data-submit>{t.form.submit}</button>
        <p class="text-xs text-[var(--color-muted)] text-center" data-form-hint>{t.form.hint}</p>
        <div class="hidden rounded-[var(--radius-button)] px-4 py-3 text-sm text-center" data-form-status role="status" aria-live="polite"></div>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const form = document.querySelector("[data-contact-form]");
    if (!form) return;
    const btn = form.querySelector("[data-submit]");
    const hint = form.querySelector("[data-form-hint]");
    const status = form.querySelector("[data-form-status]");
    const elapsedInput = form.querySelector("[data-elapsed]");
    const T = form.dataset;
    const loadedAt = Date.now();
    function show(ok, msg) {
      status.textContent = msg;
      status.classList.remove("hidden");
      status.style.background = ok ? "color-mix(in srgb, var(--color-accent) 18%, white)" : "#fde8e6";
      status.style.color = ok ? "var(--color-secondary)" : "#b42318";
    }
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      elapsedInput.value = String(Math.round((Date.now() - loadedAt) / 1000));
      btn.disabled = true;
      const original = btn.textContent;
      btn.textContent = T.sending;
      try {
        const res = await fetch(form.action, { method: "POST", body: new FormData(form), headers: { "X-Requested-With": "XMLHttpRequest", Accept: "application/json" } });
        const data = await res.json().catch(() => ({ success: res.ok }));
        if (data.success) {
          form.reset();
          if (hint) hint.classList.add("hidden");
          show(true, T.ok);
          btn.textContent = T.sent;
        } else {
          show(false, data.message || T.err);
          btn.disabled = false; btn.textContent = original;
        }
      } catch (err) {
        show(false, T.err);
        btn.disabled = false; btn.textContent = original;
      }
    });
  })();
</script>
