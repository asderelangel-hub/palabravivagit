---
import { withBase } from "../../lib/base";
import { getContent, localizePath, type Lang } from "../../i18n/content";
const { lang = "es" } = Astro.props as { lang?: Lang };
const t = getContent(lang).about;
const homeHref = withBase(localizePath("/", lang));
---
<section id="quienes" class="py-[var(--space-section)] lg:py-[var(--space-section-lg)] bg-white overflow-hidden">
  <div class="container-xl">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="relative reveal">
        <div class="absolute -top-6 -left-6 w-40 h-40 rounded-full -z-0" style="background: color-mix(in srgb, var(--color-accent) 22%, white);"></div>
        <div class="absolute -bottom-6 -right-4 w-28 h-28 rounded-[var(--radius-card)] rotate-6 -z-0" style="background: color-mix(in srgb, var(--color-primary) 16%, white);"></div>

        <div class="relative aspect-[4/5] max-w-md mx-auto overflow-hidden rounded-[var(--radius-card)] shadow-[var(--shadow-card)]">
          <img src={withBase("/fotos/leyendo.jpg")} alt="" class="ph" loading="lazy" />
        </div>

        <span class="absolute top-4 -right-3 sm:right-1 icon-chip shadow-[var(--shadow-float)] bg-white card-lift" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </span>
        <span class="absolute bottom-8 -left-3 sm:-left-5 icon-chip shadow-[var(--shadow-float)] bg-white card-lift" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2s6 7 6 11a6 6 0 0 1-12 0c0-4 6-11 6-11z"/></svg>
        </span>
        <span class="absolute -top-3 left-8 w-11 h-11 rounded-full bg-white shadow-[var(--shadow-float)] flex items-center justify-center card-lift" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#ef7a13" stroke="#ef7a13" stroke-width="1"><polygon points="12 2 15 9 22 9.3 16.5 14 18.5 21 12 17 5.5 21 7.5 14 2 9.3 9 9"/></svg>
        </span>
        <span class="absolute top-1/2 -right-4 sm:-right-6 w-11 h-11 rounded-full bg-white shadow-[var(--shadow-float)] flex items-center justify-center card-lift" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#5dbc2c" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.4 8.4 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.4 8.4 0 0 1-3.8-.9L3 21l1.9-5.7a8.4 8.4 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.4 8.4 0 0 1 3.8-.9h.5a8.5 8.5 0 0 1 8 8z"/></svg>
        </span>
        <span class="absolute -bottom-3 right-10 w-11 h-11 rounded-full bg-white shadow-[var(--shadow-float)] flex items-center justify-center card-lift" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-navy)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
        </span>
      </div>

      <div class="reveal">
        <p class="eyebrow mb-4">{t.eyebrow}</p>
        <h2 class="text-3xl sm:text-4xl lg:text-[2.9rem] font-bold leading-tight">{t.heading}</h2>
        <p class="mt-5 text-lg text-[var(--color-muted)] leading-relaxed" set:html={t.body}></p>

        <ul class="mt-8 grid sm:grid-cols-2 gap-x-6 gap-y-3.5">
          {t.features.map((f) => (
            <li class="flex items-center gap-3">
              <span class="shrink-0 w-6 h-6 rounded-full flex items-center justify-center" style="background: color-mix(in srgb, var(--color-primary) 14%, white);">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="text-[var(--color-ink)] font-medium">{f}</span>
            </li>
          ))}
        </ul>

        <a href={`${homeHref}#escuelas`} class="btn btn-primary mt-9">{t.cta}</a>
      </div>
    </div>
  </div>
</section>
