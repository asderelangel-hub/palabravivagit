---
import { withBase } from "../../lib/base";
import { getContent, type Lang } from "../../i18n/content";
const { lang = "es" } = Astro.props as { lang?: Lang };
const t = getContent(lang).stats;
const colors = ["var(--color-accent)", "#7fd4ec", "var(--color-sky)"];
---
<section class="bg-[var(--color-navy)] text-white py-[var(--space-section)] lg:py-[var(--space-section-lg)] overflow-hidden">
  <div class="container-xl">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
      <div class="relative reveal">
        <div class="relative aspect-[16/10] overflow-hidden rounded-[var(--radius-card)] shadow-[var(--shadow-float)]">
          <img src={withBase("/fotos/comunidad.jpg")} alt="" class="ph" loading="lazy" />
          <div class="absolute inset-0 bg-[var(--color-navy)]/25"></div>
          <span class="absolute inset-0 m-auto w-16 h-16 rounded-full bg-white/95 text-[var(--color-primary)] flex items-center justify-center shadow-[var(--shadow-float)]">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="ml-1"><path d="M8 5v14l11-7z"/></svg>
          </span>
          <span class="absolute bottom-3 left-3 annotation !text-white text-sm">{t.playLabel}</span>
        </div>
      </div>

      <div class="reveal">
        <p class="eyebrow !text-[var(--color-accent)] mb-4">{t.eyebrow}</p>
        <h2 class="text-3xl sm:text-4xl font-bold text-white">{t.heading}</h2>
        <p class="mt-4 text-white/75 leading-relaxed">{t.body}</p>
        <div class="mt-9 grid grid-cols-3 gap-6">
          {t.items.map((s, i) => (
            <div>
              <div class="font-display font-bold text-4xl sm:text-5xl leading-none" style={`color:${colors[i]}`}>{s.num}</div>
              <div class="mt-2 text-sm text-white/70 leading-snug">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
