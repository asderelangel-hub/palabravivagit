---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "./Header.astro";
import Serve from "./sections/Serve.astro";
import Footer from "./Footer.astro";
import { getContent, type Lang } from "../i18n/content";

const { lang = "es" } = Astro.props as { lang?: Lang };
const t = getContent(lang).servir;
---
<BaseLayout title={t.metaTitle} description={t.metaDesc} lang={lang}>
  <Header lang={lang} />
  <main>
    <Serve lang={lang} />
  </main>
  <Footer lang={lang} />
  <script is:inline>
    (function () {
      const els = document.querySelectorAll(".reveal");
      if (!("IntersectionObserver" in window) || !els.length) { els.forEach((e) => e.classList.add("is-visible")); return; }
      const io = new IntersectionObserver((entries) => { entries.forEach((en) => { if (en.isIntersecting) { en.target.classList.add("is-visible"); io.unobserve(en.target); } }); }, { threshold: 0.12 });
      els.forEach((e) => io.observe(e));
    })();
  </script>
</BaseLayout>
