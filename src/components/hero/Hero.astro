---
import { withBase } from "../../lib/base";
import { getContent, localizePath, type Lang } from "../../i18n/content";

const { lang = "es" } = Astro.props as { lang?: Lang };
const t = getContent(lang).hero;
const homeHref = withBase(localizePath("/", lang));

const meta = [
  { href: `${homeHref}#escuelas`, color: "var(--color-primary)",
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>` },
  { href: `${homeHref}#escuelas`, color: "#ef7a13",
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>` },
  { href: `${homeHref}#escuelas`, color: "var(--color-accent)",
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>` },
  { href: `${homeHref}#uofn`, color: "#5dbc2c",
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>` },
];
const cats = t.cats.map((c, i) => ({ ...c, ...meta[i] }));
---

<section id="top" class="relative min-h-screen flex flex-col overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <img src={withBase("/fotos/hero.jpg")} alt="" class="ph kenburns" fetchpriority="high" />
    <div class="absolute inset-0" style="background: linear-gradient(180deg, rgb(18 48 71 / .62) 0%, rgb(18 48 71 / .52) 45%, rgb(12 32 46 / .72) 100%);"></div>
  </div>

  <div class="container-xl relative z-10 flex-1 flex flex-col justify-center items-center text-center pt-28 pb-8">
    <p class="eyebrow !text-white/85 !tracking-[0.3em] mb-5">{t.eyebrow}</p>
    <h1 class="text-white font-extrabold text-[2.7rem] leading-[1.05] sm:text-6xl lg:text-[4.4rem] lg:leading-[1.03] max-w-4xl">
      {t.titlePre}<br class="hidden sm:block" /> <span class="italic font-medium text-[var(--color-sky)]">{t.titleEm}</span>{t.titlePost}
    </h1>
    <p class="mt-6 text-lg text-white/80 leading-relaxed max-w-2xl">{t.subtitle}</p>
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a href={`${homeHref}#escuelas`} class="btn btn-primary !rounded-[3px] !px-9 !py-4 text-base">{t.cta1}</a>
      <a href={`${homeHref}#quienes`} class="btn btn-outline-white">{t.cta2}</a>
    </div>
  </div>

  <div class="container-xl relative z-10 pb-14 lg:pb-16">
    <div class="flex justify-end pr-2 mb-2">
      <span class="annotation !text-white text-lg hidden sm:flex items-center gap-2">
        {t.annotation}
        <svg width="46" height="30" viewBox="0 0 46 30" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M2 3c12 15 27 21 41 21"/><path d="M34 20l9 4-5 5"/></svg>
      </span>
    </div>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      {cats.map((c) => (
        <a href={c.href} class="relative group rounded-[4px] border border-white/25 bg-white/10 backdrop-blur-md p-6 text-center text-white transition-colors hover:bg-white/20">
          <span class="absolute top-2.5 right-2.5 text-[0.62rem] font-bold text-white rounded-[3px] px-1.5 py-0.5" style={`background:${c.color}`}>{c.badge}</span>
          <span class="flex items-center justify-center mb-3 text-white/95" set:html={c.icon} />
          <span class="font-display font-semibold text-[0.98rem] leading-tight block">{c.title}</span>
        </a>
      ))}
    </div>
  </div>
</section>
