---
import "../styles/global.css";
import { withBase } from "../lib/base";
import { langs, defaultLang, type Lang } from "../i18n/content";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  schemaJsonLd?: Record<string, unknown>;
  gtmId?: string;
  noIndex?: boolean;
  /** Idioma de la página (es | en | pt) */
  lang?: Lang;
}

const {
  title,
  description,
  ogImage = "/og-default.jpg",
  schemaJsonLd,
  gtmId,
  noIndex = false,
  lang = "es",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://example.com").toString();
const ogImageUrl = new URL(withBase(ogImage), Astro.site ?? "https://example.com").toString();

const robotsNoIndex = noIndex || import.meta.env.BASE_URL !== "/";

// hreflang: misma página en cada idioma
const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
let rel = Astro.url.pathname.slice(BASE.length) || "/";
rel = rel.replace(/^\/(en|pt)(?=\/|$)/, "") || "/";
const hrefLangFor = (l: Lang) => {
  const p = l === defaultLang ? rel : `/${l}${rel === "/" ? "" : rel}`;
  return new URL(withBase(p), Astro.site ?? "https://example.com").toString();
};
const ogLocale = { es: "es_CL", en: "en_US", pt: "pt_BR" }[lang];
const htmlLang = { es: "es-CL", en: "en", pt: "pt-BR" }[lang];
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    {gtmId && (
      <script is:inline set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','${gtmId}');`} />
    )}

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    {robotsNoIndex && <meta name="robots" content="noindex,nofollow" />}

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {!robotsNoIndex && langs.map((l) => (
      <link rel="alternate" hreflang={l === "es" ? "es-CL" : l} href={hrefLangFor(l)} />
    ))}
    {!robotsNoIndex && <link rel="alternate" hreflang="x-default" href={hrefLangFor("es")} />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/png" href={withBase("/favicon.png")} />
    <link rel="apple-touch-icon" href={withBase("/favicon.png")} />
    <link rel="sitemap" href={withBase("/sitemap-index.xml")} />

    {schemaJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(schemaJsonLd)} />
    )}

    <slot name="head" />
  </head>
  <body>
    {gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
          title="Google Tag Manager"
        />
      </noscript>
    )}
    <slot />
  </body>
</html>
