---
import { getCollection } from "astro:content";
import PagePost from "../../components/PagePost.astro";
export async function getStaticPaths() {
  const entries = await getCollection("blog", ({ id, data }) => !data.draft && id.startsWith("es/"));
  return entries.map((entry) => ({ params: { slug: entry.id.replace(/^es\//, "") }, props: { entry } }));
}
const { entry } = Astro.props;
---
<PagePost lang="es" type="blog" entry={entry} />
