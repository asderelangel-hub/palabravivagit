---
import { getCollection } from "astro:content";
import PagePost from "../../../components/PagePost.astro";
export async function getStaticPaths() {
  const entries = await getCollection("devocionales", ({ id, data }) => !data.draft && id.startsWith("en/"));
  return entries.map((entry) => ({ params: { slug: entry.id.replace(/^en\//, "") }, props: { entry } }));
}
const { entry } = Astro.props;
---
<PagePost lang="en" type="devocionales" entry={entry} />
